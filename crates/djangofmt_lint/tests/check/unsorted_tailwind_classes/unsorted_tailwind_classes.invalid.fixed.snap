---
source: crates/djangofmt_lint/tests/check/main.rs
---
<!-- Utility classes in the wrong order -->
<div class="m-4 flex p-4"></div>

<!-- Variant utilities mixed in with their base utilities -->
<button class="m-4 flex p-4 hover:p-1">Save</button>

<!-- Display/layout utilities reordered -->
<span class="flex inline flex-col">Label</span>

<!-- Responsive variants regrouped by breakpoint -->
<div class="hidden sm:flex md:grid lg:block"></div>

<!-- Dark-mode variant ordering -->
<div class="bg-white p-2 dark:bg-gray-800"></div>

<!-- Real-world Example -->
<a class="btn mt-4 bg-blue-700 text-white hover:bg-blue-900">Sign up</a>
<button class="focus:ring-primary-300 rounded-lg bg-purple-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-purple-800 focus:ring-4">Submit</button>

<!-- With prefix (v3) -->
<a class="tw-text-white tw-bg-blue-700 btn hover:tw-bg-blue-900 tw-mt-4">Sign up</a>
<button class="tw-text-white tw-bg-purple-600 hover:tw-bg-purple-800 focus:tw-ring-4 focus:tw-ring-primary-300 tw-font-medium tw-rounded-lg tw-text-sm tw-px-5 tw-py-2.5">Submit</button>

<!-- With prefix (v4) -->
<a class="btn tw:mt-4 tw:bg-blue-700 tw:text-white tw:hover:bg-blue-900">Sign up</a>
<button class="tw:focus:ring-primary-300 tw:rounded-lg tw:bg-purple-600 tw:px-5 tw:py-2.5 tw:text-sm tw:font-medium tw:text-white tw:hover:bg-purple-800 tw:focus:ring-4">Submit</button>
